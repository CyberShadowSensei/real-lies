# TruthLens Backend Environment Variables (Example for backend/ folder)

# FastAPI server settings
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000
DEBUG_MODE=True

# Groq API Keys (for LLM and Whisper)
# It is highly recommended to provide multiple keys for rotation and rate limit handling.
GROQ_API_KEY_1="your_groq_api_key_1"
GROQ_API_KEY_2="your_groq_api_key_2"
# ... add more as needed

# OpenRouter API Keys (for Vision LLM)
# It is highly recommended to provide multiple keys for rotation and rate limit handling.
OPENROUTER_API_KEY_1="your_openrouter_api_key_1"
OPENROUTER_API_KEY_2="your_openrouter_api_key_2"
# ... add more as needed

# Google Fact Check Tools API Key
GOOGLE_FACT_CHECK_API_KEY="your_google_fact_check_api_key"

# Add any other environment variables as needed
# Example:
# CACHE_TYPE: str = os.getenv("CACHE_TYPE", "in_memory")

# --- IMPORTANT ---
# If you run the backend from the 'backend/' directory directly (e.g., `uvicorn main:app`),
# copy this file to `.env` in the same directory and fill in your API keys.
# If you run the backend from the project root (e.g., `uvicorn backend.main:app`),
# use the `.env` file in the project root.
